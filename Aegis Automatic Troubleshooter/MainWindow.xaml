<Window x:Class="Aegis_Automatic_Troubleshooter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infrastructure="clr-namespace:Aegis_Automatic_Troubleshooter.Infrastructure"
        xmlns:models="clr-namespace:Aegis_Automatic_Troubleshooter.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Aegis Troubleshooter"
        Height="900"
        Width="1360"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <infrastructure:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <Geometry x:Key="AegisMarkGeometry">M12,2 L20,6 V12.5 C20,17.2 16.7,20.4 12,22 C7.3,20.4 4,17.2 4,12.5 V6 Z M12,5.4 L8.2,7.2 V12.5 C8.2,15.1 9.6,17 12,18.3 C14.4,17 15.8,15.1 15.8,12.5 V7.2 Z M12,7.5 L14.2,15 H12.8 L12,12.4 L11.2,15 H9.8 Z</Geometry>
        <Geometry x:Key="ScanIconGeometry">M3,12 H7.5 L9.5,7 L13.5,18 L16,12 H21</Geometry>
        <Geometry x:Key="FindingsIconGeometry">M5,4 H19 M5,9 H19 M5,14 H15 M5,19 H12 M3,4 H3.5 M3,9 H3.5 M3,14 H3.5 M3,19 H3.5</Geometry>
        <Geometry x:Key="FixIconGeometry">M14,4 C16.5,2.4 20,4.2 20,7.2 C20,7.9 19.9,8.4 19.6,9 L16,9 L15,12 L12,13 L9,16 L8,19 L5,20 L3.8,18.8 L4.8,15.8 L7.8,14 L11,10.8 L12,8 L11.8,4.4 C12.4,4.2 13.1,4.1 14,4 Z</Geometry>
        <Geometry x:Key="EvidenceIconGeometry">M5,3 H15 L20,8 V21 H5 Z M15,3 V8 H20 M8,13 H16 M8,17 H13</Geometry>
        <Geometry x:Key="GuideIconGeometry">M4,5 C6,4 8,4 10,5 V20 C8,19 6,19 4,20 Z M10,5 C12,4 14,4 16,5 V20 C14,19 12,19 10,20 Z M16,5 C18,4 20,4 21,5 V20 C19,19 18,19 16,20 Z</Geometry>
        <Geometry x:Key="TargetIconGeometry">M5,3 H15 L20,8 V21 H5 Z M15,3 V8 H20 M8,13 H16 M8,17 H13 M8,8 H11</Geometry>
        <Geometry x:Key="FolderIconGeometry">M3,6 H9 L11,8 H21 V19 H3 Z</Geometry>
        <Geometry x:Key="PlayIconGeometry">M8,5 L19,12 L8,19 Z</Geometry>
        <Geometry x:Key="ExportIconGeometry">M12,3 V15 M8,11 L12,15 L16,11 M5,18 H19 V21 H5 Z</Geometry>
        <Geometry x:Key="PackageIconGeometry">M12,2 L20,6.5 V15.5 L12,22 L4,15.5 V6.5 Z M12,2 V22 M4,6.5 L12,11 L20,6.5</Geometry>
        <Geometry x:Key="WarningIconGeometry">M12,3 L21,19 H3 Z M12,8 V13 M12,16 V17</Geometry>
        <Geometry x:Key="FailedIconGeometry">M7,7 L17,17 M17,7 L7,17 M12,2 L20,6 V12 C20,17 16.5,20 12,22 C7.5,20 4,17 4,12 V6 Z</Geometry>
        <Geometry x:Key="PassedIconGeometry">M8.5,13.5 L11,16 L16.5,8.5 M12,2 L20,6 V12 C20,17 16.5,20 12,22 C7.5,20 4,17 4,12 V6 Z</Geometry>
        <Geometry x:Key="MinimizeIconGeometry">M5,12 H19</Geometry>
        <Geometry x:Key="MaximizeIconGeometry">M6,6 H18 V18 H6 Z</Geometry>
        <Geometry x:Key="CloseIconGeometry">M7,7 L17,17 M17,7 L7,17</Geometry>

        <Style x:Key="IconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="#FF4B55" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#20242C" />
            <Setter Property="Background" Value="#0E1117" />
        </Style>

        <Style x:Key="MetricPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#D1242F" />
            <Setter Property="BorderBrush" Value="#EF4444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E0313B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#AA1F29" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#151922" />
            <Setter Property="BorderBrush" Value="#303642" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B202A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#DDE3EA" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#171C24" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#242A34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#EEF2F7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#1B2028"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10141A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#303642" />
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#191012" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7C2D33" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="Background" Value="#080A0F" />
            <Setter Property="BorderBrush" Value="#2B313C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF4B55" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <DataTemplate x:Key="CompactModuleTemplate" DataType="{x:Type models:GuideModule}">
            <Border BorderBrush="#1E252E"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#0B0E13"
                    Padding="10"
                    Margin="0,0,8,8"
                    Width="246"
                    Height="58">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            CornerRadius="6"
                            Background="#1A1012"
                            BorderBrush="#563038"
                            BorderThickness="1">
                        <Path Data="{Binding IconGeometry}"
                              Style="{StaticResource IconPathStyle}"
                              Stroke="#FF4B55"
                              Width="17"
                              Height="17"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#F3F6FA"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}"
                                   Foreground="#9EA8B5"
                                   FontSize="10"
                                   Margin="0,3,0,0"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FindingRowTemplate" DataType="{x:Type models:DiagnosticItem}">
            <Border BorderBrush="#1D232C"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{Binding StatusSurfaceBrush}"
                            BorderBrush="{Binding StatusBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="28"
                            Padding="9,0"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{Binding StatusIconGeometry}"
                                  Style="{StaticResource IconPathStyle}"
                                  Stroke="{Binding StatusBrush}"
                                  Width="13"
                                  Height="13" />
                            <TextBlock Text="{Binding StatusLabel}"
                                       Foreground="{Binding StatusBrush}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="5,0,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,16,0">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Summary}"
                                   Foreground="#B8C2CF"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <Path Data="{Binding SeverityIconGeometry}"
                              Style="{StaticResource IconPathStyle}"
                              Stroke="#DCE2EA"
                              Width="14"
                              Height="14" />
                        <TextBlock Text="{Binding SeverityLabel}"
                                   Foreground="#DCE2EA"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiagnosticDetailTemplate" DataType="{x:Type models:DiagnosticItem}">
            <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{Binding StatusSurfaceBrush}"
                                    BorderBrush="{Binding StatusBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="9,4">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{Binding StatusIconGeometry}"
                                          Style="{StaticResource IconPathStyle}"
                                          Stroke="{Binding StatusBrush}"
                                          Width="13"
                                          Height="13" />
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontWeight="Bold" FontSize="11" Margin="5,0,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding Category}" Foreground="#9EA8B5" FontWeight="SemiBold" Margin="10,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Path Data="{Binding SeverityIconGeometry}"
                                  Style="{StaticResource IconPathStyle}"
                                  Stroke="#DCE2EA"
                                  Width="14"
                                  Height="14" />
                            <TextBlock Text="{Binding SeverityLabel}" Foreground="#DCE2EA" FontWeight="SemiBold" Margin="6,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Summary}" Foreground="#D3DAE3" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Evidence}" Foreground="#AAB4C1" Margin="0,10,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Recommendation}" Foreground="#EEF2F6" Margin="0,10,0,0" TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding Actions}"
                                  Margin="0,14,0,0"
                                  Visibility="{Binding HasActions, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DiagnosticAction}">
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"
                                        Padding="12,7"
                                        MinHeight="34"
                                        Command="{Binding DataContext.ExecuteDiagnosticActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource FixIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="14" Height="14" />
                                        <TextBlock Text="{Binding Title}" Margin="7,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="InstallPackageTemplate" DataType="{x:Type models:InstallPackage}">
            <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="16" />
                            <Border Margin="10,0,0,0"
                                    Padding="9,3"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="{Binding StatusBrush}"
                                    Background="#08000000">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource PackageIconGeometry}"
                                          Style="{StaticResource IconPathStyle}"
                                          Stroke="{Binding StatusBrush}"
                                          Width="12"
                                          Height="12" />
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontWeight="Bold" FontSize="11" Margin="5,0,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" Foreground="#B8C2CF" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Evidence}" Foreground="#8F9AA8" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="112"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.InstallPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource PackageIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Width="14" Height="14" />
                            <TextBlock Text="Install" Margin="7,0,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ScanHistoryTemplate" DataType="{x:Type models:ScanHistoryEntry}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="154" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="86" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding TimestampLabel}" Foreground="#C6CED8" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding ApplicationName}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding ResultLabel}" Foreground="{Binding ResultBrush}" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{Binding IssueLabel}" Foreground="#C6CED8" FontSize="12" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="8"
            CornerRadius="14"
            BorderBrush="#26303A"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#050608" Offset="0" />
                <GradientStop Color="#080A0E" Offset="0.55" />
                <GradientStop Color="#0E0708" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,0,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="18" Height="18" CornerRadius="4" BorderBrush="#B7353D" BorderThickness="1" Background="#181012">
                        <Path Data="{StaticResource AegisMarkGeometry}"
                              Style="{StaticResource IconPathStyle}"
                              Stroke="#FF4B55"
                              StrokeThickness="1.5"
                              Width="12"
                              Height="12"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Aegis Troubleshooter"
                               Foreground="#DDE4ED"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding BusyLabel}"
                               Foreground="#8D98A8"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="MinimizeWindow_Click">
                        <Path Data="{StaticResource MinimizeIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE3EA" Width="14" Height="14" />
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="ToggleMaximizeWindow_Click">
                        <Path Data="{StaticResource MaximizeIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE3EA" Width="13" Height="13" />
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="CloseWindow_Click">
                        <Path Data="{StaticResource CloseIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE3EA" Width="13" Height="13" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#1B2028"
                        BorderThickness="0,1,1,0"
                        CornerRadius="0,0,0,14"
                        Background="#06080B">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left"
                                    Background="#190F11"
                                    BorderBrush="#78313A"
                                    BorderThickness="1">
                                <Path Data="{StaticResource AegisMarkGeometry}"
                                      Style="{StaticResource IconPathStyle}"
                                      Stroke="#FF4B55"
                                      StrokeThickness="1.7"
                                      Width="28"
                                      Height="28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="AEGIS"
                                       Foreground="#FF4B55"
                                       FontFamily="Bahnschrift"
                                       FontWeight="Bold"
                                       FontSize="23"
                                       Margin="0,18,0,0" />
                            <TextBlock Text="TROUBLESHOOTER"
                                       Foreground="#EAF0F7"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,30,0,0">
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Tag="{Binding IsHomeSection}"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="Home">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource ScanIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Scan Console" Foreground="#F4F7FB" FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Tag="{Binding IsResultsSection}"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="Results">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource FindingsIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#D8E0EA" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Findings" Foreground="#F4F7FB" FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Tag="{Binding IsInstallersSection}"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="Installers">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource FixIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#D8E0EA" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Fix Center" Foreground="#F4F7FB" FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Tag="{Binding IsActivitySection}"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="Activity">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource EvidenceIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#D8E0EA" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Evidence Log" Foreground="#F4F7FB" FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Tag="{Binding IsGuideSection}"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="Guide">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource GuideIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#D8E0EA" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Guide Map" Foreground="#F4F7FB" FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource PanelStyle}"
                                Padding="14"
                                VerticalAlignment="Bottom">
                            <StackPanel>
                                <TextBlock Text="TARGET"
                                           Style="{StaticResource SectionLabelStyle}" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30"
                                            Height="30"
                                            CornerRadius="6"
                                            Background="#1A1012"
                                            BorderBrush="#563038"
                                            BorderThickness="1">
                                        <Path Data="{StaticResource TargetIconGeometry}"
                                              Style="{StaticResource IconPathStyle}"
                                              Stroke="#FF4B55"
                                              Width="17"
                                              Height="17"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding SelectedApplicationName}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40" />
                                        <TextBlock Text="{Binding SelectedApplicationVersion}"
                                                   Foreground="#9EA8B5"
                                                   FontSize="12"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="36" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding SelectedApplicationLocation}"
                                           Foreground="#8F9AA8"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="58" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,14,0,0"
                                        MinHeight="38"
                                        Padding="12,7"
                                        Click="BrowseApp_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource FolderIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                        <TextBlock Text="Change Target" Margin="7,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding AppVersion}"
                                   Foreground="#7F8A99"
                                   Margin="0,16,0,0" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,18,20,18" ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76" />
                        <RowDefinition Height="164" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Diagnostic Console"
                                       Foreground="#F6F8FA"
                                       FontFamily="Bahnschrift"
                                       FontWeight="Bold"
                                       FontSize="31" />
                            <TextBlock Text="Detect startup blockers, runtime gaps, permission problems, crash evidence, and network failures."
                                       Foreground="#B9C3D0"
                                       Margin="0,6,0,0"
                                       FontSize="14" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource PanelStyle}"
                                Padding="14"
                                Background="#100F0F">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="38"
                                        Height="38"
                                        CornerRadius="8"
                                        Background="{Binding StatusSurfaceBrush}"
                                        BorderBrush="{Binding StatusBrush}"
                                        BorderThickness="1">
                                    <Path Data="{Binding StatusIconGeometry}"
                                          Style="{StaticResource IconPathStyle}"
                                          Stroke="{Binding StatusBrush}"
                                          StrokeThickness="1.9"
                                          Width="21"
                                          Height="21"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding StatusToneLabel}"
                                               Foreground="{Binding StatusBrush}"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding StatusHeadline}"
                                               Foreground="#F6F8FA"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource PanelStyle}"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Application executable" Foreground="#9EA8B5" FontSize="12" FontWeight="SemiBold" />
                                <TextBox Text="{Binding SelectedAppPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Margin="0,6,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,22,0,0"
                                    MinHeight="40"
                                    Padding="10,8"
                                    Click="BrowseApp_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FolderIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                    <TextBlock Text="Browse" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,22,0,0"
                                    MinHeight="40"
                                    Padding="10,8"
                                    Command="{Binding RunDiagnosticsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource PlayIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Width="14" Height="14" />
                                    <TextBlock Text="Run Scan" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,22,0,0"
                                    MinHeight="40"
                                    Padding="10,8"
                                    Click="ExportReport_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource ExportIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                    <TextBlock Text="Export" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="4">
                                <TextBlock Text="Server endpoint" Foreground="#9EA8B5" FontSize="12" FontWeight="SemiBold" />
                                <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,14,0,0" ClipToBounds="True">
                        <Grid Visibility="{Binding IsHomeSection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="200" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="104" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="380" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="SCAN RUNWAY" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding StatusText}" Foreground="#D4DCE6" FontSize="15" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="1" Columns="5" Margin="0,10,0,8">
                                        <Border CornerRadius="8" BorderBrush="#29313B" BorderThickness="1" Background="#0A0D12" Margin="0,0,7,0" Padding="7">
                                            <StackPanel>
                                                <Path Data="{StaticResource TargetIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Left" />
                                                <TextBlock Text="Select App" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="8" BorderBrush="#29313B" BorderThickness="1" Background="#0A0D12" Margin="0,0,7,0" Padding="7">
                                            <StackPanel>
                                                <Path Data="{StaticResource PassedIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Left" />
                                                <TextBlock Text="Security" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="8" BorderBrush="#29313B" BorderThickness="1" Background="#0A0D12" Margin="0,0,7,0" Padding="7">
                                            <StackPanel>
                                                <Path Data="{StaticResource PackageIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Left" />
                                                <TextBlock Text="Runtimes" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="8" BorderBrush="#29313B" BorderThickness="1" Background="#0A0D12" Margin="0,0,7,0" Padding="7">
                                            <StackPanel>
                                                <Path Data="{StaticResource EvidenceIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Left" />
                                                <TextBlock Text="Evidence" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="8" BorderBrush="#29313B" BorderThickness="1" Background="#0A0D12" Padding="7">
                                            <StackPanel>
                                                <Path Data="{StaticResource ExportIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF4B55" Width="18" Height="18" HorizontalAlignment="Left" />
                                                <TextBlock Text="Report" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Button Grid.Row="2"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="210"
                                            MinHeight="36"
                                            Padding="12,7"
                                            HorizontalAlignment="Left"
                                            Command="{Binding RunDiagnosticsCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource PlayIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Width="14" Height="14" />
                                            <TextBlock Text="Start Diagnostic Scan" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="88" Height="88" CornerRadius="12" Background="{Binding StatusSurfaceBrush}" BorderBrush="{Binding StatusBrush}" BorderThickness="2">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{Binding StatusIconGeometry}"
                                                      Style="{StaticResource IconPathStyle}"
                                                      Stroke="{Binding StatusBrush}"
                                                      Width="22"
                                                      Height="22"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,0,4" />
                                                <TextBlock Text="{Binding ReadinessScoreLabel}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                                                <TextBlock Text="READY" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource MetricPanelStyle}" Background="#0A1410" Margin="0,0,8,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource PassedIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#7DDB95" Width="14" Height="14" />
                                                    <TextBlock Text="Passed" Foreground="#7DDB95" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding PassedCount}" Foreground="White" FontWeight="Bold" FontSize="26" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource MetricPanelStyle}" Background="#19130B" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource WarningIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#F2BB63" Width="14" Height="14" />
                                                    <TextBlock Text="Warnings" Foreground="#F2BB63" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding WarningCount}" Foreground="White" FontWeight="Bold" FontSize="26" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Style="{StaticResource MetricPanelStyle}" Background="#1A0D10" Margin="0,0,8,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource FailedIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF7F87" Width="14" Height="14" />
                                                    <TextBlock Text="Failed" Foreground="#FF7F87" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding FailedCount}" Foreground="White" FontWeight="Bold" FontSize="26" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MetricPanelStyle}" Background="#0C111A">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource PackageIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#95B5FF" Width="14" Height="14" />
                                                    <TextBlock Text="Packages" Foreground="#95B5FF" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding MissingPackageCount}" Foreground="White" FontWeight="Bold" FontSize="26" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="0,16,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="PRIORITY FINDINGS" Style="{StaticResource SectionLabelStyle}" />
                                            <TextBlock Text="Highest-impact blockers from the latest scan." Foreground="#9EA8B5" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="12,6"
                                                MinHeight="32"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="Results">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource FindingsIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="14" Height="14" />
                                                <TextBlock Text="View All" Margin="7,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding PriorityDiagnostics}"
                                                          ItemTemplate="{StaticResource FindingRowTemplate}"
                                                          Visibility="{Binding HasPriorityDiagnostics, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <TextBlock Text="No blockers surfaced on the latest pass."
                                                       Foreground="#8F9AA8"
                                                       Visibility="{Binding HasPriorityDiagnostics, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelStyle}" Margin="0,16,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="GUIDE COVERAGE" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="The modules match the troubleshooting text guide." Foreground="#9EA8B5" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding GuideModules}"
                                                  ItemTemplate="{StaticResource CompactModuleTemplate}"
                                                  Margin="0,14,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RECENT SCANS" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding LastScanLabel}" Foreground="#9EA8B5" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <ItemsControl Grid.Column="1"
                                                  ItemsSource="{Binding ScanHistory}"
                                                  ItemTemplate="{StaticResource ScanHistoryTemplate}"
                                                  Visibility="{Binding HasScanHistory, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Run a scan to create history."
                                               Foreground="#8F9AA8"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasScanHistory, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding IsResultsSection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="FINDINGS" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Problem, evidence, recommendation, and supported action for each check." Foreground="#B8C2CF" Margin="0,7,0,0" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Diagnostics}" ItemTemplate="{StaticResource DiagnosticDetailTemplate}" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="SUMMARY" Style="{StaticResource SectionLabelStyle}" />
                                    <TextBlock Text="{Binding StatusHeadline}" Foreground="White" FontWeight="SemiBold" FontSize="20" Margin="0,12,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding StatusSubtext}" Foreground="#B8C2CF" Margin="0,10,0,0" TextWrapping="Wrap" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Margin="0,22,0,0" Command="{Binding InstallMissingPackagesCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource PackageIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Width="14" Height="14" />
                                            <TextBlock Text="Install Missing Packages" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" Click="ExportReport_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource ExportIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                            <TextBlock Text="Export Report" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" Click="OpenGuide_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource GuideIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                            <TextBlock Text="Open Text Guide" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding IsInstallersSection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="82" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="FIX CENTER" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding PackageHeadline}" Foreground="White" FontWeight="SemiBold" FontSize="20" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            MinWidth="210"
                                            Command="{Binding InstallMissingPackagesCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource PackageIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Width="14" Height="14" />
                                            <TextBlock Text="Install Missing Packages" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding InstallPackages}" ItemTemplate="{StaticResource InstallPackageTemplate}" />
                            </ScrollViewer>
                        </Grid>

                        <Grid Visibility="{Binding IsActivitySection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="420" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="CRASH EVIDENCE" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Application and Windows Error Reporting events related to the selected target." Foreground="#B8C2CF" Margin="0,7,0,0" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CrashEvents}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:CrashEventInfo}">
                                                    <Border BorderBrush="#1D232C" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Timestamp}" Foreground="White" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ModuleName}" Foreground="#FFB366" Margin="0,5,0,0" />
                                                            <TextBlock Text="{Binding ExceptionCode}" Foreground="#B8C2CF" Margin="0,5,0,0" />
                                                            <TextBlock Text="{Binding Message}" Foreground="#8F9AA8" Margin="0,5,0,0" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ACTIVITY NOTES" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Scan output, environmental notes, and remediation feedback." Foreground="#B8C2CF" Margin="0,7,0,0" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ActivityNotes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#1D232C" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding}" Foreground="#D4DCE6" TextWrapping="Wrap" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding IsGuideSection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="WORKFLOW" Style="{StaticResource SectionLabelStyle}" />
                                    <TextBlock Text="Select App" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,20,0,0" />
                                    <TextBlock Text="Run Full Diagnostic" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,16,0,0" />
                                    <TextBlock Text="Show Results" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,16,0,0" />
                                    <TextBlock Text="Show Fix Recommendations" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,16,0,0" />
                                    <TextBlock Text="Export Report" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,16,0,0" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,28,0,0" Click="OpenGuide_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource GuideIconGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#DDE4ED" Width="15" Height="15" />
                                            <TextBlock Text="Open Text Guide" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="MODULE MAP" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Coverage mirrors the text guide so the app feels connected to the actual support process." Foreground="#B8C2CF" Margin="0,7,0,0" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding GuideModules}" ItemTemplate="{StaticResource CompactModuleTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
